# 注释一律单独成行，别写在 KEY=value 后面（python-dotenv 会把行内注释当成值）。

# ===== Matrix 账号 =====
# 填你自己的账号=以你本人身份收发；填专用 bot 账号=机器人身份
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@you:matrix.org
# 仅首次登录需要；成功后凭证存到 store/credentials.json，可删掉
MATRIX_PASSWORD=
MATRIX_DEVICE_NAME=claude-bot
MATRIX_STORE_PATH=./store
MATRIX_CREDS_PATH=./store/credentials.json
# 装好 libolm + matrix-nio[e2e] 后设为 1
MATRIX_ENABLE_E2E=0

# ===== 行为 =====
# 只在这些房间工作（逗号分隔 !roomid:server）；留空=全部
ROOM_ALLOWLIST=
# 只响应这些人派的活、也只接受这些人的邀请；留空=所有人都能驱动 Claude
ALLOW_USERS=
# 1=单聊(2人房间)消息一律处理
REPLY_IN_DM_ALWAYS=1
# 1=不被@也对"像求助"的消息主动判断要不要插话（实验性）
PROACTIVE=0
# 每个房间主动发言的最小间隔（秒）
PROACTIVE_COOLDOWN=120
# 判定"这次不插话"后占用的短冷却（秒）；太小会让活跃群里几乎每条疑问都起一次 Claude 判断（烧钱）
PROACTIVE_PASS_COOLDOWN=60
# 可选触发词，例如 claude
TRIGGER_PHRASE=
# 喂给任务/主动判断的最近消息条数（人类消息和 bot 回复共享）；0=不带背景
CONTEXT_LINES=20
# 1=处理离线期间堆积的消息
PROCESS_BACKLOG=0

# ===== Gitea / 项目路由（每个群 ↔ 一个仓库）=====
# Gitea 个人访问令牌：clone 私有库 + 开 PR
GITEA_TOKEN=
# 受信任的 Gitea 根地址，如 https://gitea.example.com
# token 只注入到这个主机；fail-closed：不设就完全不识别任何仓库。要用仓库功能必填。
GITEA_HOST=
# 仓库 clone 到这里（./projects/<host>/<owner>/<repo>）
PROJECTS_ROOT=./projects
BINDINGS_PATH=./store/bindings.json
# 提交作者
GIT_USER_NAME=claude-bot
GIT_USER_EMAIL=claude-bot@localhost
# 单次 git 操作（尤其 clone）超时（秒）
GIT_TIMEOUT=300
# 用法：群里发仓库地址或 /bind <url> 绑定房间；DM 按内容自动分诊

# ===== Claude Code =====
CLAUDE_BIN=claude
# 留空用默认模型；可填 claude-opus-4-8 等
CLAUDE_MODEL=
# 未绑定仓库时的兜底工作目录；留空=PROJECTS_ROOT/_scratch。别指到含 .env / store/ 的目录
CLAUDE_WORKDIR=
# 单次任务超时（秒）
CLAUDE_TIMEOUT=600
# DM 分诊 / 主动插话等轻量判断的单独超时（秒），别和 CLAUDE_TIMEOUT 混用
CLAUDE_QUICK_TIMEOUT=60
CLAUDE_SYSTEM_PROMPT=你是通过 Matrix 接入的助手，会被派来干活（写代码、查问题、做方案等）。用简洁中文回复。
CLAUDE_PERMISSION_MODE=acceptEdits
# 1=加 --dangerously-skip-permissions 全自动干活；0 更安全但会卡在需要授权的工具上
CLAUDE_DANGEROUS=1
# 追加给 claude 的参数，如 --allowedTools "Bash Read Edit"
CLAUDE_EXTRA_ARGS=
# 每个房间多轮上下文的空闲过期（秒）
SESSION_TTL=7200
# 同时最多跑几个 Claude 任务
MAX_CONCURRENCY=2
# 项目长期记忆：跨会话/跨重启留存的「每项目」事实库（决策+原因、约定、长期目标、踩过的坑），
# 补会话 TTL 之外的「长程记忆」。1=开（默认），0=关
MEMORY_ENABLED=1
# 开新会话时注入系统提示的事实正文字符预算（索引始终全量注入；超预算的留在磁盘按需读）
MEMORY_RECALL_BUDGET=6000
# PR 台账：bot 开了 PR 就跟到合并——轮询评审/CI，收到评审意见或 CI 失败自动处理并回报到原房间。1=开（默认）
PR_FOLLOWUP_ENABLED=1
# 巡检间隔（秒）
PR_FOLLOWUP_INTERVAL=180
# 每个 PR 自动处理评审/CI 的次数上限，防反复失败时空转（超过只回报、不再自动改）
PR_AUTOFIX_MAX=3
# 主动性·自驱心跳：没人派活时也巡检各项目主动找事。1=开（默认，只读巡检+提议）
PROACTIVE_HEARTBEAT_ENABLED=1
# 巡检间隔（秒），别太密以免烧钱/打扰
PROACTIVE_HEARTBEAT_INTERVAL=3600
# 0=只提议等你点头（默认，安全）；1=autopilot：巡检到就自己认领、开 PR（无人值守自主行动，慎开）
PROACTIVE_AUTOPILOT=0

# ===== 媒体（图片 / 文件 / 音视频）=====
# 1=下载群/私聊里发来的文件存到本地、需要时供 Claude 读取；0=只在上下文标记"有人发了文件"
MEDIA_ENABLED=1
# 媒体落盘目录；留空=PROJECTS_ROOT/_media
MEDIA_ROOT=
# 单个文件下载上限（MB），超过跳过（homeserver 的上传上限再兜一层）
MEDIA_MAX_MB=25
# 每个房间最多保留几个媒体文件，超出按时间删旧
MEDIA_KEEP=50
