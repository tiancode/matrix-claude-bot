# 注释一律单独成行，别写在 KEY=value 后面（python-dotenv 会把行内注释当成值）。

# ===== Matrix 账号 =====
# 填你自己的账号=以你本人身份收发；填专用 bot 账号=机器人身份
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@you:matrix.org
# 仅首次登录需要；成功后凭证存到 store/credentials.json，可删掉
MATRIX_PASSWORD=
MATRIX_DEVICE_NAME=claude-bot
MATRIX_STORE_PATH=./store
MATRIX_CREDS_PATH=./store/credentials.json
# 装好 libolm + matrix-nio[e2e] 后设为 1
MATRIX_ENABLE_E2E=0
# 自建 / 自签名证书 homeserver 才需要（公网 homeserver 留空即可）。默认走系统 CA 校验，
# 遇自签名证书会一直连不上（nio 默认校验证书）。两种接法：
# ① 推荐——把服务器证书存成文件，指向它，仍做校验、仍防 MITM（要求证书 SAN 覆盖你连的主机名/IP）：
#      echo | openssl s_client -connect 主机:443 2>/dev/null | openssl x509 > homeserver.crt
#    MATRIX_CA_CERT=./homeserver.crt
# ② 省事——直接关证书校验（失去 MITM 防护，仅可信内网/自有机器）：MATRIX_SSL_VERIFY=0
MATRIX_CA_CERT=
MATRIX_SSL_VERIFY=1

# ===== 行为 =====
# 注意：本 bot 不做访问控制——任何能给它发消息的人都能驱动 Claude（跑命令、读写文件、用 GITEA_TOKEN
# clone/读私有库）、谁邀请都进房。只在你信任所有可达用户的环境用（如仅 LAN 可达、关了注册的私有 homeserver）。
# 1=单聊(2人房间)消息一律处理
REPLY_IN_DM_ALWAYS=1
# 1=不被@也对群消息主动判断要不要插话（求助、或对话里有值得纠正的错误）。默认开
PROACTIVE=1
# 每个房间主动发言的最小间隔（秒）
PROACTIVE_COOLDOWN=120
# 判定"这次不插话"后占用的短冷却（秒）；太小会让活跃群里几乎每条疑问都起一次 Claude 判断（烧钱）
PROACTIVE_PASS_COOLDOWN=60
# 0=对每条群消息都判断要不要插话——能抓到"没人求助但话里有错"（同事聊错了你纠正），默认；
# 1=只对含求助/报错词的消息做判断（省判断调用）。靠冷却+强__PASS__倾向兜底防刷屏
PROACTIVE_REQUIRE_HINT=0
# 群里"对话延续窗口"（秒）：@ 过 bot 后这段时间内的后续消息免重复 @ 也接着处理
# （@别人、或窗口内有第三人插话则不算续话）。0=关，默认 180
GROUP_FOLLOWUP_WINDOW=180
# 续话窗口命中属"弱信号"：再过一道轻量语义闸，确认确实在接着跟 bot 说、而非转头跟旁人说/自言自语，
# 堵"没话找话"的误触发。用 CLAUDE_QUICK_MODEL 小模型判、拿不准仍当在跟你说。0=关（回到纯规则），默认 1
GROUP_FOLLOWUP_SEMANTIC_GATE=1
# 群答复的组织方式。0（默认）=答复直接发在主时间线，发送那一刻群里已插进别的消息时自动改用
# 「引用回复」指明在回哪条；用户自己在线程里说话则跟进该线程。与 bot 按房间拍平的记忆一致，不再 fork。
# 1=旧式：每条顶层消息的答复都挂进它的线程(m.thread)——多话题强分流，但多轮会碎成一堆小线程
REPLY_IN_THREAD=0
# 1=流式：发占位消息后随 Claude 产出【边生成边编辑】同一条消息，长任务不再全程静默。默认开
STREAM_REPLIES=1
# 1=允许把【工作目录内】文件作为附件回传（Claude 在回复里写 [[send-file: 路径]] 触发）。默认开
SEND_FILES_BACK=1
# /summarize 不带参数时默认回看多少条对话做 catch-up 小结
SUMMARY_LINES=60
# 可选触发词，例如 claude
TRIGGER_PHRASE=
# 喂给任务/主动判断的最近消息条数（人类消息和 bot 回复共享）；0=不带背景
CONTEXT_LINES=20
# 1=处理离线期间堆积的消息
PROCESS_BACKLOG=0

# ===== Gitea / 项目路由（每个群 ↔ 一个仓库）=====
# Gitea 个人访问令牌：clone 私有库 + 开 PR
GITEA_TOKEN=
# 受信任的 Gitea 根地址，如 https://gitea.example.com
# token 只注入到这个主机；fail-closed：不设就完全不识别任何仓库。要用仓库功能必填。
GITEA_HOST=
# 仓库 clone 到这里（./projects/<host>/<owner>/<repo>）
PROJECTS_ROOT=./projects
BINDINGS_PATH=./store/bindings.json
# 提交作者
GIT_USER_NAME=claude-bot
GIT_USER_EMAIL=claude-bot@localhost
# 单次 git 操作（尤其 clone）超时（秒）
GIT_TIMEOUT=300
# 用法：群里发仓库地址或 /bind <url> 绑定房间；DM 按内容自动分诊

# ===== Claude Code =====
CLAUDE_BIN=claude
# 留空用默认模型；可填别名（opus / sonnet / haiku）或完整 ID（claude-opus-4-8 等）
CLAUDE_MODEL=
# 轻判断单独的模型：DM 分诊、主动插话判定、只读查证——群里几乎每条消息一次，
# 用小模型（如 haiku）省钱且更快；干活的 ask() 仍用 CLAUDE_MODEL。留空=跟随 CLAUDE_MODEL
CLAUDE_QUICK_MODEL=
# 未绑定仓库时的兜底工作目录；留空=PROJECTS_ROOT/_scratch。别指到含 .env / store/ 的目录
CLAUDE_WORKDIR=
# 单次任务超时（秒）
CLAUDE_TIMEOUT=600
# DM 分诊 / 主动插话等轻量判断的单独超时（秒），别和 CLAUDE_TIMEOUT 混用
CLAUDE_QUICK_TIMEOUT=60
CLAUDE_SYSTEM_PROMPT=你是通过 Matrix 接入的助手，会被派来干活（写代码、查问题、做方案等）。用简洁中文回复。
CLAUDE_PERMISSION_MODE=acceptEdits
# 1=加 --dangerously-skip-permissions 全自动干活；0 更安全但会卡在需要授权的工具上
CLAUDE_DANGEROUS=1
# 追加给 claude 的参数，如 --allowedTools "Bash Read Edit"
CLAUDE_EXTRA_ARGS=
# 每个房间多轮上下文的空闲过期（秒）；默认 86400=24 小时
SESSION_TTL=86400
# 同时最多跑几个 Claude 任务
MAX_CONCURRENCY=2
# 聊天逐字记录：1=按房间把对话明文落盘 store/transcripts/<房间>.jsonl，问"前天聊了什么"时 Claude
# 自己读它回溯（补会话 TTL / 背景缓冲都够不着的远期对话）。默认开。会持久留存全部对话明文，
# 仅记授权用户、store/ 0700、受保留天数约束。0=关。/backfill [天数] 可从 Matrix 回灌开启前的历史
TRANSCRIPT_ENABLED=1
# 保留天数（超期滚动删旧）/ 每房间行数硬上限 / 回灌默认往回天数
TRANSCRIPT_KEEP_DAYS=30
TRANSCRIPT_MAX_LINES=5000
TRANSCRIPT_BACKFILL_DAYS=30
# 聊天日摘要 + 主题索引：在逐字日志之上再叠一层可 KB 级检索的漏斗（store/transcripts/digests/<房间>/），
# 被问"昨天中午聊过什么 / 以前讨论过某某"时先按天定位摘要、按需回原文，不必整段读原始日志。默认开。
# 后台用 CLAUDE_QUICK_MODEL 把当天对话压成话题摘要（需 TRANSCRIPT_ENABLED=1 才有原料）。1=开，0=关
DIGEST_ENABLED=1
# 触发阈值：水位线后攒够 MIN_LINES 新行 + 距上次运行 ≥ MIN_INTERVAL 秒 → 生成（跨天残留另有 600s 快收尾）
DIGEST_MIN_LINES=30
DIGEST_MIN_INTERVAL=7200
# 摘要保留天数（超期删日文件 + 同步删索引行）/ 日期分桶 & HH:MM 显示用的固定时区偏移（东八区=8）
DIGEST_KEEP_DAYS=180
DIGEST_TZ_HOURS=8
# 项目长期记忆：跨会话/跨重启留存的「每项目」事实库（决策+原因、约定、长期目标、踩过的坑），
# 补会话 TTL 之外的「长程记忆」。1=开（默认），0=关
MEMORY_ENABLED=1
# 开新会话时注入系统提示的事实正文字符预算（索引始终全量注入；超预算的留在磁盘按需读）
MEMORY_RECALL_BUDGET=6000
# PR 台账：bot 开了 PR 就跟到合并——轮询评审/CI，收到评审意见或 CI 失败自动处理并回报到原房间。1=开（默认）
PR_FOLLOWUP_ENABLED=1
# 巡检间隔（秒）
PR_FOLLOWUP_INTERVAL=180
# 每个 PR 自动处理评审/CI 的次数上限，防反复失败时空转（超过只回报、不再自动改）
PR_AUTOFIX_MAX=3
# Gitea 工单接活：把 issue 指派给 bot 的 Gitea 账号 = 派活（不进 Matrix 也能下任务）。
# 轮询各已知项目 assigned 给 bot 的 open issue：认领（issue 下评论）→ 干活开 PR（body 带
# Closes #N，合并即自动关单）→ PR 进台账盯到合并 → 进展回报到项目房间。1=开（默认）
ISSUE_INTAKE=1
# 轮询间隔（秒）
ISSUE_POLL_INTERVAL=300
# 主动性·自驱心跳：没人派活时也巡检各项目主动找事。1=开（默认，只读巡检+提议）
PROACTIVE_HEARTBEAT_ENABLED=1
# 巡检间隔（秒），别太密以免烧钱/打扰
PROACTIVE_HEARTBEAT_INTERVAL=3600
# 1=autopilot：巡检到就自己认领、开 PR（无人值守自主行动）。默认开；0=只提议等你点头（更安全）
PROACTIVE_AUTOPILOT=1

# ===== PR 自动合并 =====
# followup 巡检到 PR 可合并 + CI 通过（或没配 CI）+ 无未决"请求改动" → 直接调 Gitea API 合并，无需人工点。
# 机械闸、不经 Claude 评审；安全性靠 CI（若配了）+ 快照环境兜底。1=开（默认），0=关。
# 配合 autopilot 即"巡检→开 PR→自动合并"全自动闭环；没配 CI 时唯一的闸是"git 能干净合并"
PR_AUTOMERGE=1
# 合并方式：merge / squash / rebase（须为仓库允许的方式）
PR_MERGE_METHOD=merge
# 合并后删除源分支 claude/xxx
PR_AUTOMERGE_DELETE_BRANCH=1

# ===== 媒体（图片 / 文件 / 音视频）=====
# 1=下载群/私聊里发来的文件存到本地、需要时供 Claude 读取；0=只在上下文标记"有人发了文件"
MEDIA_ENABLED=1
# 媒体落盘目录；留空=PROJECTS_ROOT/_media
MEDIA_ROOT=
# 单个文件下载上限（MB），超过跳过（homeserver 的上传上限再兜一层）
MEDIA_MAX_MB=25
# 每个房间最多保留几个媒体文件，超出按时间删旧
MEDIA_KEEP=50
